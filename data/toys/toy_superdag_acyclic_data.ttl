@prefix ex: <http://example.org/superdag-acyclic#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ex:alice rdf:type ex:Person ;
    ex:likes ex:chess .

ex:bob rdf:type ex:Person ;
    ex:likes ex:alice .

ex:carol rdf:type ex:Person ;
    ex:likes ex:bob .

ex:emma rdf:type ex:Person ;
    ex:likes ex:stamps .

ex:frank rdf:type ex:Person ;
    ex:likes ex:emma .

ex:chess rdf:type ex:Interest .
ex:stamps rdf:type ex:Interest .
