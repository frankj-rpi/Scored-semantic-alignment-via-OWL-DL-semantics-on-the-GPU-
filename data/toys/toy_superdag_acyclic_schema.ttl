@prefix ex: <http://example.org/superdag-acyclic#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Person a owl:Class .
ex:Interest a owl:Class .

ex:Alpha a owl:Class ;
    rdfs:subClassOf ex:Beta .

ex:Beta a owl:Class ;
    rdfs:subClassOf ex:Alpha .

ex:likes a owl:ObjectProperty .

ex:PeopleWithHobby a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [
                a owl:Restriction ;
                owl:onProperty ex:likes ;
                owl:someValuesFrom ex:Interest
            ]
        )
    ] .

ex:PeopleWithHobbyFan a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [
                a owl:Restriction ;
                owl:onProperty ex:likes ;
                owl:someValuesFrom ex:PeopleWithHobby
            ]
        )
    ] .

ex:PeopleWithHobbyFanFan a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [
                a owl:Restriction ;
                owl:onProperty ex:likes ;
                owl:someValuesFrom ex:PeopleWithHobbyFan
            ]
        )
    ] .

ex:Collector a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [
                a owl:Restriction ;
                owl:onProperty ex:likes ;
                owl:someValuesFrom ex:Interest
            ]
        )
    ] .

ex:CollectorFan a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [
                a owl:Restriction ;
                owl:onProperty ex:likes ;
                owl:someValuesFrom ex:Collector
            ]
        )
    ] .
