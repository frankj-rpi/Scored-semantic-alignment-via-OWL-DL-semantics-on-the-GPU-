@prefix ex: <http://example.org/superdag-scc#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Person a owl:Class .
ex:likes a owl:ObjectProperty .

ex:A a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [
                a owl:Restriction ;
                owl:onProperty ex:likes ;
                owl:someValuesFrom ex:B
            ]
        )
    ] .

ex:B a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [
                a owl:Restriction ;
                owl:onProperty ex:likes ;
                owl:someValuesFrom ex:A
            ]
        )
    ] .

ex:Downstream a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [
                a owl:Restriction ;
                owl:onProperty ex:likes ;
                owl:someValuesFrom ex:B
            ]
        )
    ] .

ex:Tail a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [
                a owl:Restriction ;
                owl:onProperty ex:likes ;
                owl:someValuesFrom ex:Downstream
            ]
        )
    ] .
