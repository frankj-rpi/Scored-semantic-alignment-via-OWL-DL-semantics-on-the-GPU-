@prefix ex: <http://example.org/functionaldata#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ssn a owl:DatatypeProperty , owl:FunctionalProperty .
ex:code a owl:DatatypeProperty , owl:FunctionalProperty .

ex:HasSSN123 a owl:Class ;
    owl:equivalentClass [
        a owl:Restriction ;
        owl:onProperty ex:ssn ;
        owl:hasValue "123"^^xsd:string
    ] .

ex:CodeAce a owl:Class ;
    owl:equivalentClass [
        a owl:Restriction ;
        owl:onProperty ex:code ;
        owl:someValuesFrom [
            a rdfs:Datatype ;
            owl:oneOf ( "ACE"^^xsd:string )
        ]
    ] .
