@prefix ex: <http://example.org/negative-assertion#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ex:alice a owl:NamedIndividual, ex:Person .
ex:bob a owl:NamedIndividual, ex:Person, ex:Guardian .

ex:alice a [
   owl:complementOf ex:Forbidden
] .
