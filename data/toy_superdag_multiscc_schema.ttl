@prefix ex: <http://example.org/superdag-multiscc#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Person a owl:Class .
ex:likes a owl:ObjectProperty .

ex:A1 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:B1 ]
        )
    ] .

ex:B1 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:A1 ]
        )
    ] .

ex:C1 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:B1 ]
        )
    ] .

ex:D1 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:A1 ]
        )
    ] .

ex:A2 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:B2 ]
        )
    ] .

ex:SeedA2 a owl:Class ;
    rdfs:subClassOf ex:A2 ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:C1 ]
        )
    ] .

ex:B2 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:A2 ]
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:D1 ]
        )
    ] .

ex:E2 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:A2 ]
        )
    ] .

ex:F2 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:B2 ]
        )
    ] .

ex:A3 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:B3 ]
        )
    ] .

ex:SeedA3 a owl:Class ;
    rdfs:subClassOf ex:A3 ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:E2 ]
        )
    ] .

ex:B3 a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:A3 ]
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:F2 ]
        )
    ] .

ex:TailLeft a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:A3 ]
        )
    ] .

ex:TailRight a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:B3 ]
        )
    ] .

ex:Final a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:TailLeft ]
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:TailRight ]
        )
    ] .
