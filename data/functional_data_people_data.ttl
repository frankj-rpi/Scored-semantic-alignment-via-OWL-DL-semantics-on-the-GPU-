@prefix ex: <http://example.org/functionaldata#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:alice a owl:NamedIndividual ;
    ex:ssn "123"^^xsd:string .

ex:bob a owl:NamedIndividual ;
    ex:ssn "456"^^xsd:string .

ex:carol a owl:NamedIndividual ;
    ex:ssn "123"^^xsd:string, "999"^^xsd:string .

ex:dave a owl:NamedIndividual ;
    ex:code "ACE"^^xsd:string .

ex:erin a owl:NamedIndividual ;
    ex:code "ACE"^^xsd:string, "BEE"^^xsd:string .
