@prefix ex: <http://example.org/negation#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:NegationOntology a owl:Ontology .

ex:Robot a owl:Class .

ex:OrganicPerson a owl:Class ;
    rdfs:subClassOf foaf:Person ;
    rdfs:subClassOf [
        owl:complementOf ex:Robot
    ] .

ex:DisjointOrganicPerson a owl:Class ;
    rdfs:subClassOf foaf:Person ;
    owl:disjointWith ex:Robot .
