@prefix ex: <http://example.org/connected#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

ex:alice a foaf:Person ;
    foaf:knows ex:bob ;
    foaf:name "Alice" .

ex:bob a foaf:Person ;
    foaf:name "Bob" .

ex:carol a foaf:Person ;
    foaf:knows ex:projectX ;
    foaf:name "Carol" .

ex:dave a foaf:Person ;
    foaf:name "Dave" .

ex:projectX foaf:name "Project X" .
