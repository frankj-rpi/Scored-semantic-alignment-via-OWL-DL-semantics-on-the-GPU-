@prefix ns1: <urn:dag-consistency:0#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

ns1:node2 a owl:NamedIndividual,
        ns1:BaseClass0,
        ns1:BaseClass1,
        ns1:BaseClass2 ;
    ns1:prop0 ns1:node0,
        ns1:node3,
        ns1:node4 ;
    ns1:prop2 ns1:node3,
        ns1:node4 ;
    ns1:prop3 ns1:node1,
        ns1:node3 .

ns1:node4 a owl:NamedIndividual,
        ns1:BaseClass1,
        ns1:BaseClass2 ;
    ns1:prop1 ns1:node0 ;
    ns1:prop2 ns1:node1 .

ns1:node3 a owl:NamedIndividual,
        ns1:BaseClass1 ;
    ns1:prop0 ns1:node0,
        ns1:node1 ;
    ns1:prop1 ns1:node0 ;
    ns1:prop2 ns1:node2,
        ns1:node4 ;
    ns1:prop3 ns1:node1 .

ns1:node0 a owl:NamedIndividual,
        ns1:BaseClass0 ;
    ns1:prop2 ns1:node1,
        ns1:node3 .

ns1:node1 a owl:NamedIndividual,
        ns1:BaseClass2 ;
    ns1:prop0 ns1:node2 ;
    ns1:prop3 ns1:node0 .

