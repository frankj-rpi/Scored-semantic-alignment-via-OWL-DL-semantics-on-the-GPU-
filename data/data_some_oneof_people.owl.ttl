@prefix ex: <http://example.org/datasome#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:nickname a owl:DatatypeProperty .

ex:HasNicknameString a owl:Class ;
    owl:equivalentClass [
        a owl:Restriction ;
        owl:onProperty ex:nickname ;
        owl:someValuesFrom xsd:string
    ] .

ex:NicknameAce a owl:Class ;
    owl:equivalentClass [
        a owl:Restriction ;
        owl:onProperty ex:nickname ;
        owl:someValuesFrom [
            a rdfs:Datatype ;
            owl:oneOf ( "Ace"^^xsd:string )
        ]
    ] .
