@prefix ex: <http://example.org/equality#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ex:anchor a owl:NamedIndividual, ex:Marked .
ex:alias a owl:NamedIndividual, ex:Marked ;
  owl:sameAs ex:anchor .
ex:outsider a owl:NamedIndividual ;
  owl:differentFrom ex:anchor .
