@prefix ex: <http://example.org/union#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:UnionOntology a owl:Ontology .

ex:Engineer a owl:Class ;
    rdfs:subClassOf foaf:Person .

ex:Artist a owl:Class ;
    rdfs:subClassOf foaf:Person .

ex:CreativeOrTechnical a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:unionOf ( ex:Engineer ex:Artist )
    ] .

ex:KnowsCreativeOrTechnical a owl:Class ;
    rdfs:subClassOf foaf:Person ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty foaf:knows ;
        owl:someValuesFrom [
            a owl:Class ;
            owl:unionOf ( ex:Engineer ex:Artist )
        ]
    ] .
