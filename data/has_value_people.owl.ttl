@prefix ex: <http://example.org/hasvalue#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:hasPet a owl:ObjectProperty .
ex:nickname a owl:DatatypeProperty .

ex:OwnsFido a owl:Class ;
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ex:hasPet ;
    owl:hasValue ex:fido
  ] .

ex:NicknameAce a owl:Class ;
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ex:nickname ;
    owl:hasValue "Ace"
  ] .
