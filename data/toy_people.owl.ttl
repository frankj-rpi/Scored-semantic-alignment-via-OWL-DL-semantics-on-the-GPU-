@prefix ex: <http://example.org/toy#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:ToyOntology a owl:Ontology .

ex:Wheel a owl:Class .
ex:Furniture a owl:Class .
ex:FurnitureWithWheel a owl:Class ;
    rdfs:subClassOf ex:Furniture ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty ex:hasPart ;
        owl:someValuesFrom ex:Wheel
    ] .

ex:hasPart a owl:ObjectProperty .
