@prefix ex: <http://example.org/sameas-native#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Person a owl:Class .
ex:Selected a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:oneOf ( ex:anchor )
    ] .

ex:likes a owl:ObjectProperty .

ex:LikesSelected a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            ex:Person
            [ a owl:Restriction ; owl:onProperty ex:likes ; owl:someValuesFrom ex:Selected ]
        )
    ] .
