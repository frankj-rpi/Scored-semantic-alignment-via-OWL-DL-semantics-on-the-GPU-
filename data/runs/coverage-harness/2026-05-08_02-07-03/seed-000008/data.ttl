@prefix ns1: <urn:dag-consistency:8#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:node2 a owl:NamedIndividual,
        ns1:BaseClass1,
        ns1:BaseClass3 ;
    ns1:prop0 ns1:node1,
        ns1:node3,
        ns1:node4 .

ns1:node6 a owl:NamedIndividual,
        ns1:BaseClass0,
        ns1:BaseClass1 ;
    ns1:dataProp1 2 ;
    ns1:prop0 ns1:node2,
        ns1:node7 ;
    ns1:prop2 ns1:node1,
        ns1:node7 .

ns1:node1 a owl:NamedIndividual,
        ns1:BaseClass3 ;
    ns1:dataProp0 12 ;
    ns1:dataProp1 21 ;
    ns1:prop0 ns1:node0 ;
    ns1:prop1 ns1:node4,
        ns1:node7 ;
    ns1:prop2 ns1:node3 .

ns1:node4 a owl:NamedIndividual,
        ns1:BaseClass0,
        ns1:BaseClass3 ;
    ns1:dataProp0 2 ;
    ns1:dataProp1 7 ;
    ns1:prop0 ns1:node5 .

ns1:node5 a owl:NamedIndividual,
        ns1:BaseClass2,
        ns1:BaseClass3,
        ns1:BaseClass4 ;
    ns1:dataProp0 "alpha"^^xsd:string ;
    ns1:dataProp1 7 ;
    ns1:prop0 ns1:node1,
        ns1:node7 ;
    ns1:prop2 ns1:node0,
        ns1:node3 .

ns1:node0 a owl:NamedIndividual,
        ns1:BaseClass0,
        ns1:BaseClass3 ;
    ns1:dataProp0 "beta"^^xsd:string ;
    ns1:dataProp1 16 ;
    ns1:prop0 ns1:node5 ;
    ns1:prop1 ns1:node7 ;
    ns1:prop2 ns1:node0,
        ns1:node6 .

ns1:node3 a owl:NamedIndividual,
        ns1:BaseClass3,
        ns1:BaseClass4 ;
    ns1:dataProp0 "alpha"^^xsd:string ;
    ns1:dataProp1 7 ;
    ns1:prop0 ns1:node4,
        ns1:node5,
        ns1:node6 ;
    ns1:prop1 ns1:node2 .

ns1:node7 a owl:NamedIndividual,
        ns1:BaseClass1,
        ns1:BaseClass3 ;
    ns1:dataProp0 16 ;
    ns1:dataProp1 27 ;
    ns1:prop0 ns1:node0,
        ns1:node3 .

