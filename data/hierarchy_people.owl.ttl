@prefix ex: <http://example.org/hierarchy#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:HierarchyOntology a owl:Ontology .

ex:Employee a owl:Class ;
    rdfs:subClassOf foaf:Person .

ex:friendOf a owl:ObjectProperty ;
    rdfs:subPropertyOf foaf:knows .

ex:FriendlyEmployee a owl:Class ;
    rdfs:subClassOf ex:Employee ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty foaf:knows ;
        owl:someValuesFrom foaf:Person
    ] .
